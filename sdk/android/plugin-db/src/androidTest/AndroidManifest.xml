<?xml version="1.0" encoding="utf-8"?>
<!--
  Test APK manifest for plugin-db instrumented tests.
  Sets networkSecurityConfig to allow cleartext traffic to localhost so
  MockWebServer (which binds to http://localhost) works on API 28+ devices.
  Mirrors plugin-network's androidTest manifest. This config is only included
  in the androidTest APK, never in production builds.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <application
        android:networkSecurityConfig="@xml/network_security_config"
        tools:replace="android:networkSecurityConfig" />
</manifest>
